# Copy this file to .env and fill in values
#
# Notes:
# - Use `redis://` for non-TLS Redis.
# - Use `rediss://` for TLS (Redis Cloud commonly requires TLS).
# - With auth: rediss://default:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT/0
#

# ===== Redis: input stream (jobs) =====
REDIS_STREAM_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT/0
REDIS_STREAM_KEY=stream:jobs:0
REDIS_CONSUMER_GROUP=smartmoney-ai
# Optional; if left default, worker will derive from hostname/pid
REDIS_CONSUMER_NAME=smartmoney-ai-1

# Block time for XREADGROUP (ms)
REDIS_BLOCK_MS=5000
# Min idle time before reclaiming pending messages (ms)
REDIS_CLAIM_IDLE_MS=60000
# Max delivery attempts before dead-lettering (if enabled)
REDIS_MAX_RETRIES=10
# Optional dead-letter stream key (leave empty to disable)
REDIS_DEAD_LETTER_STREAM_KEY=

# ===== Redis: result storage =====
REDIS_RESULT_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT/1
# Store job:{jobId} for 1 day
RESULT_TTL_SECONDS=86400

# ===== Cloudinary download limits =====
DOWNLOAD_MAX_BYTES=26214400
DOWNLOAD_TIMEOUT_SECONDS=30

# ===== ASR settings (voice duty) =====
# This project uses `moonshine-voice` for ASR.
# Set the language code used to select the model.
ASR_LANGUAGE=vi

# ===== LLM providers =====
# Set at least one provider key to use app/services/llm/service.py
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash